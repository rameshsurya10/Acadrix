DEBUG=True
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL — settings.py reads these individual vars (not DATABASE_URL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=acadrix
DB_USER=acadrix
DB_PASSWORD=acadrix_dev_password
# require | prefer | disable. Use 'disable' for local Postgres without SSL.
DB_SSLMODE=prefer

CORS_ALLOWED_ORIGINS=http://localhost:5173

JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Redis (also used as Celery broker if CELERY_BROKER_URL not set)
REDIS_URL=redis://localhost:6379/0

# Celery (override only if you want a separate broker)
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# SMTP Email Configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=Acadrix <noreply@acadrix.com>

# Google OAuth2
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# AI / LLM — Anthropic Claude (used by principal's AI question generator, Phase 3.1)
# Leave ANTHROPIC_API_KEY empty to disable AI features.
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
ANTHROPIC_MAX_INPUT_CHARS=40000

# SMS Provider — MSG91 (https://msg91.com)
# Leave MSG91_AUTH_KEY empty in dev: send_otp_sms() will print to console.
# In production: register a DLT template with ##OTP## placeholder, then fill these.
MSG91_AUTH_KEY=
MSG91_OTP_TEMPLATE_ID=
MSG91_SENDER_ID=ACDRIX
MSG91_COUNTRY_CODE=91

# Payment Gateway — Razorpay (https://razorpay.com)
# Leave RAZORPAY_KEY_ID empty in dev: online payments will be disabled.
# Test credentials start with rzp_test_, live with rzp_live_.
# RAZORPAY_WEBHOOK_SECRET is SEPARATE from the API secret — set it in the
# Razorpay dashboard under Settings -> Webhooks.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_CURRENCY=INR

# File Storage — S3 / Cloudflare R2 / Backblaze B2 / MinIO
# Set USE_S3_STORAGE=True to route all user uploads (avatars, docs, photos)
# to a remote bucket instead of local /media. When False, uploads stay on disk.
USE_S3_STORAGE=False

# Leave AWS_S3_ENDPOINT_URL empty for real AWS S3. For other providers:
#   Cloudflare R2:  https://<account-id>.r2.cloudflarestorage.com
#   Backblaze B2:   https://s3.<region>.backblazeb2.com
#   MinIO (local):  http://minio:9000
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=ap-south-1
AWS_S3_ENDPOINT_URL=
# Optional CDN hostname (CloudFront, Bunny, etc.). Blank = serve from bucket directly.
AWS_S3_CUSTOM_DOMAIN=
# Bucket subfolder — keeps uploads namespaced if you share a bucket across envs
AWS_LOCATION=media
# True = signed URLs (private files, expire after 1h). False = public bucket.
AWS_QUERYSTRING_AUTH=True
AWS_QUERYSTRING_EXPIRE=3600
